#!/bin/bash
# shellcheck disable=SC2034,SC2088,SC2148
# Natilius Base Profile
# Description: Shared base configuration for all profiles
# Common configuration shared across all profiles
# Other profiles can source this: source ~/.natiliusrc.base

# ============================================================================
# CORE SETTINGS
# ============================================================================
COUNTRYCODE="us"
SKIP_UPDATE_CHECK=false

# ============================================================================
# DIRECTORIES
# ============================================================================
DIRS=(
    "~/.config"
    "~/GIT"
)

DIRSTOEXCLUDEFROMTIMEMACHINE=(
    "~/GIT"
    "~/.gnupg"
    "~/.ssh"
    "~/.config"
    "~/.aws"
    "~/.bun"
    "~/.cache"
    "~/.cursor/worktrees"
    "~/.factory/sessions"
    "~/.ollama/models"
    "~/.npm"
    "~/.cargo"
    "~/.local/share/pnpm"
)

# ============================================================================
# HOMEBREW TAPS (Essential)
# ============================================================================
BREWTAPS=(
    "homebrew/cask"
    "github/gh"
)

# ============================================================================
# HOMEBREW PACKAGES (Core Tools)
# ============================================================================
BREWPACKAGES=(
    # Version Control
    "git"
    "gh"
    "git-lfs"
    "git-xet"

    # Shell Essentials
    "coreutils"
    "curl"
    "wget"
    "jq"
    "fzf"
    "bat"
    "eza"
    "fd"
    "ripgrep"
    "tree"
    "htop"
    "procs"
    "zoxide"

    # Media & Preview
    "ffmpeg"
    "imagemagick"
    "poppler"
    "p7zip"
    "resvg"

    # Security
    "gpg"
    "pinentry-mac"
    "openssh"
    "openssl"
    "ca-certificates"
    "ykman"

    # Remote Access
    "mosh"

    # Utilities
    "mackup"
    "mas"
    "trash"
    "watch"
    "tmux"
    "neovim"
    "tealdeer"
    "vhs"

    # Fonts (essential)
    "font-fira-code"
    "font-fira-code-nerd-font"
    "font-meslo-lg-nerd-font"
)

# ============================================================================
# HOMEBREW CASKS (Core Apps)
# ============================================================================
BREWCASKS=(
    # Security
    "1password"
    "1password-cli"

    # Terminal & Development
    "iterm2"
    "visual-studio-code"

    # Git Client (choose: github, tower, fork, gitkraken)
    "github"

    # Productivity & System
    "raycast"           # Alternative: "alfred"
    "alt-tab"
    "the-unarchiver"
    "monitorcontrol"    # Alternative: "betterdisplay"
    "bartender"
    "stats"             # System monitor in menubar

    # Networking
    "tailscale-app"     # Mesh VPN (includes CLI)

    # Communication
    "slack"
    "zoom"
)

# ============================================================================
# MAC APP STORE (Core)
# ============================================================================
APPSTORE=(
    "441258766"   # Magnet (window management)
    "937984704"   # Amphetamine (prevent sleep)
)

# ============================================================================
# APPS TO RESTART AFTER SETUP
# ============================================================================
KILLAPPS=(
    "Dock"
    "Finder"
    "SystemUIServer"
)
