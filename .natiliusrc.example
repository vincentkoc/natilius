#!/bin/bash
# shellcheck disable=SC2034,SC2088,SC2148
# Natilius Configuration
#
# This file controls which modules run and what gets installed.
# Copy to ~/.natiliusrc before running natilius.
#
# PROFILE INHERITANCE:
# For role-based setups, you can source a base config:
#   source ~/.natiliusrc.base
#   ENABLED_MODULES+=("dev_environments/python")  # Add to base modules
#
# See profiles/ directory for ready-to-use templates:
#   - minimal.natiliusrc   - Quick onboarding, essentials only
#   - devops.natiliusrc    - Kubernetes, Terraform, cloud tools
#   - developer.natiliusrc - Full dev environment with multiple languages
#
# Usage with profiles:
#   natilius --profile devops
#   natilius --profile minimal

# Enabled modules
# "system/system_update"
# "system/directories"
# "system/security"
# "preferences/mac_preferences"
# "preferences/system_preferences"
# "applications/homebrew"
# "applications/apps"
# "applications/espanso"
# "dev_environments/java"
# "dev_environments/ruby"
# "dev_environments/python"
# "dev_environments/node"
# "dev_environments/rust"
# "dev_environments/go"
# "dev_environments/php"
# "dev_environments/flutter"
# "ide/ide_setup"
# "dotfiles"
# "system/cleanup"
ENABLED_MODULES=(
    "system/cleanup"
)

# Custom variables
COUNTRYCODE="us"
JDKVER="20"
PYTHONVER="3.13.0"
RUBYVER="3.4.2"
NODEVER="22.20.0"
GOVER="1.20.0"
PHPVER="8.1.0"
FLUTTER_CHANNEL="stable"
NATILIUS_INSTALL_OHMYZSH=true

# Set to true to skip update checks
SKIP_UPDATE_CHECK=false

# Use Mole for deep cleanup (more thorough than built-in)
# See: https://github.com/tw93/Mole
USE_MOLE_CLEANUP=false

# IDE Configuration
INSTALL_VSCODE=true
INSTALL_CURSOR=false
INSTALL_JETBRAINS=true
INSTALL_SUBLIME=false
INSTALL_ZED=false

# Enterprise/MDM Configuration
# Set to true if your organization uses Jamf
ENTERPRISE_MODE=false
# Skip installations that conflict with MDM policies
RESPECT_MDM_POLICIES=true
# Run Jamf recon after setup completes
JAMF_RECON_ON_COMPLETE=false

# Directories to create
DIRS=(
    "~/.mackup"
    "~/.config"
    "~/GIT"
    "~/Library/Mobile Documents/com~apple~CloudDocs/dotfiles"
)

# Time Machine exclusions
DIRSTOEXCLUDEFROMTIMEMACHINE=(
    "~/.mackup"
    "~/GIT"
    "~/Dropbox"
    "~/.gnupg"
    "~/.ssh"
    "~/.config"
    "~/.aws"
    "~/.bun"
    "~/.cache"
    "~/.cursor/worktrees"
    "~/.factory/sessions"
    "~/.ollama/models"
    "~/.npm"
    "~/.cargo"
    "~/.local/share/pnpm"
    "~/.pyenv"
    "~/.rbenv"
    "~/.rustup"
    "~/.nodenv"
    "~/go"
)

# Homebrew Taps
BREWTAPS=(
    "homebrew/cask"
    "adoptopenjdk/openjdk"
    "github/gh"
    "r-lib/rig"
    "rfidresearchgroup/proxmark3"
    "mongodb/brew"
    "warrensbox/tap"
    "derailed/popeye"
)

