#!/bin/bash
# shellcheck disable=SC2034,SC2088,SC2148
# Natilius Example Configuration (Full)
#
# Copy to ~/.natiliusrc before running natilius.
# This is a full-featured example mirroring the base style but enabling all modules.

# ============================================================================
# CORE SETTINGS
# ============================================================================
COUNTRYCODE="us"
SKIP_UPDATE_CHECK=false
NATILIUS_INSTALL_OHMYZSH=true

# ============================================================================
# ENABLED MODULES (Full)
# ============================================================================
ENABLED_MODULES=(
    "system/system_update"
    "system/directories"
    # "system/repositories"
    "system/security"
    "preferences/mac_preferences"
    "preferences/system_preferences"
    "applications/homebrew"
    "applications/apps"
    "applications/espanso"
    "dev_environments/java"
    "dev_environments/ruby"
    "dev_environments/python"
    "dev_environments/node"
    "dev_environments/rust"
    "dev_environments/go"
    "dev_environments/php"
    "dev_environments/flutter"
    "ide/ide_setup"
    "dotfiles"
    "system/cleanup"
)

# ============================================================================
# ENTERPRISE / MDM SETTINGS
# ============================================================================
ENTERPRISE_MODE=false
RESPECT_MDM_POLICIES=true
JAMF_RECON_ON_COMPLETE=false

# ============================================================================
# CLEANUP SETTINGS
# ============================================================================
USE_MOLE_CLEANUP=true

# ============================================================================
# LANGUAGE VERSIONS
# ============================================================================
JDKVER="20"
PYTHONVER="3.13.0"
RUBYVER="3.4.2"
NODEVER="24.13.0"
NPMVER="11.8.0"
GOVER="1.20.0"
PHPVER="8.1.0"
FLUTTER_CHANNEL="stable"

# ============================================================================
# IDE CONFIGURATION
# ============================================================================
INSTALL_VSCODE=true
INSTALL_CURSOR=false
INSTALL_JETBRAINS=true
INSTALL_SUBLIME=false
INSTALL_ZED=false

# ============================================================================
# DIRECTORIES
# ============================================================================
DIRS=(
    "~/.mackup"
    "~/.config"
    "~/GIT"
    "~/Library/Mobile Documents/com~apple~CloudDocs/dotfiles"
)

DIRSTOEXCLUDEFROMTIMEMACHINE=(
    "~/.mackup"
    "~/GIT"
    "~/Dropbox"
    "~/.gnupg"
    "~/.ssh"
    "~/.config"
    "~/.aws"
    "~/.bun"
    "~/.cache"
    "~/.cursor/worktrees"
    "~/.factory/sessions"
    "~/.ollama/models"
    "~/.npm"
    "~/.cargo"
    "~/.local/share/pnpm"
    "~/.pyenv"
    "~/.rbenv"
    "~/.rustup"
    "~/.nodenv"
    "~/go"
)

# ============================================================================
# GIT REPOSITORIES
# ============================================================================
# Optional repositories to clone. Entries are "owner/repo:destination"; relative
# destinations are created under GIT_REPO_BASE_DIR.
GIT_REPO_BASE_DIR="$HOME/GIT/_Perso"
GIT_REPOS=(
    # "vincentkoc/tokenjuice:tokenjuice"
)

# ============================================================================
# HOMEBREW TAPS
# ============================================================================
